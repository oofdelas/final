local function getHeldBrainrotName(plr)
    local char = plr and plr.Character
    if not char then return nil end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            local n = tool.Name
            local l = n:lower()
            if l ~= "flying carpet" and l ~= "quantum cloner" and l ~= "bat" and l ~= "glove" then
                return n
            end
        end
    end
    return nil
end

local function isPriorityBrainrot(name)
    if type(name) ~= "string" or name == "" then return false end
    local lower = name:lower()
    for _, p in ipairs(PRIORITY_LIST or {}) do
        if type(p) == "string" and p:lower() == lower then
            return true
        end
    end
    return false
end

