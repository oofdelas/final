    local cache = SharedState.AllAnimalsCache
    local priority = (Config.PriorityList and type(Config.PriorityList) == "table" and #Config.PriorityList > 0) and Config.PriorityList or PRIORITY_LIST
    if cache and type(cache) == "table" then
        if State.lastStealTargetUID then
