        local priority = (Config.PriorityList and #Config.PriorityList > 0)
                         and Config.PriorityList or PRIORITY_LIST
        for _, pName in ipairs(priority) do
            local sn = pName:lower()
            for _, a in ipairs(cache) do
                if a and a.name and a.name:lower() == sn and isMyBaseAnimal(a) then
                    return a
                end
            end
        end
        -- Fallback: maior gen própria base
        local best, bestGv = nil, -1
        for _, a in ipairs(cache) do
            if a and isMyBaseAnimal(a) then
                local gv = tonumber(a.genValue) or 0
                if gv > bestGv then bestGv = gv; best = a end
