-- Retorna a posição lateral DENTRO da base, na beira dos slots (como na imagem 2).
-- O boneco para no X central da base, Z offset de ~45 studs do centro (beira dos slots laterais).
-- Detecta qual lado (norte/sul) está mais próximo do player.
local SIDE_SLOT_OFFSET_Z = 45  -- distância do centro Z até a beira lateral dos slots
local function getSideClonePosition(baseIdx, playerPos, isHigh)
    local basePos = isHigh and BASES_HIGH[baseIdx] or BASES_LOW[baseIdx]
    if not basePos then return nil, nil, nil end

    -- X dentro da base: usa o X central da base (não a borda frontal)
    -- Grupo 1–4: X≈-460, grupo 5–8: X≈-355
    local insideX = basePos.X
    local insideY = isHigh and basePos.Y or -4

    local zCenter = basePos.Z

    -- Dois lados da beira dos slots
    local zNorth = zCenter + SIDE_SLOT_OFFSET_Z
    local zSouth = zCenter - SIDE_SLOT_OFFSET_Z

    -- Escolhe o lado mais próximo do player no eixo Z
    local chosenZ
    if math.abs(playerPos.Z - zNorth) <= math.abs(playerPos.Z - zSouth) then
        chosenZ = zNorth
    else
        chosenZ = zSouth
    end

    -- Posição final: dentro da base, na beira lateral dos slots
    local clonePos = Vector3.new(insideX, insideY, chosenZ)

    -- Face target: olha para o centro Z da base (de lado para dentro)
    local faceTarget = Vector3.new(insideX, insideY, zCenter)

    -- LookVector pré-calculado para girar o boneco antes do TP
    local lookDir = (faceTarget - clonePos).Unit

    return clonePos, faceTarget, lookDir
end

local function getClosestBaseIdx(pos)
    local closest, dist = 1, math.huge
    for i, basePos in pairs(BASES_LOW) do
        local d = (Vector2.new(pos.X, pos.Z) - Vector2.new(basePos.X, basePos.Z)).Magnitude
        if d < dist then dist = d; closest = i end
    end
    return closest
end

