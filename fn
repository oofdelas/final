local function findNearestWallHit(maxDist)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local origin = hrp.Position + Vector3.new(0, 2, 0)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {char}

    local dirs = {
        Vector3.new(1, 0, 0), Vector3.new(-1, 0, 0),
        Vector3.new(0, 0, 1), Vector3.new(0, 0, -1),
        (Vector3.new(1, 0, 1)).Unit, (Vector3.new(1, 0, -1)).Unit,
        (Vector3.new(-1, 0, 1)).Unit, (Vector3.new(-1, 0, -1)).Unit,
    }

    local best = nil
    local bestDist = (maxDist or 60) + 1
    for i = 1, #dirs do
        local dir = dirs[i]
        local result = Workspace:Raycast(origin, dir * (maxDist or 60), rayParams)
        if result and result.Instance and result.Instance:IsA("BasePart") then
            local d = (result.Position - origin).Magnitude
            if d < bestDist then
                bestDist = d
                best = {result = result, dir = dir, origin = origin, hrp = hrp}
            end
        end
    end
    return best
end

local function computeWallSnapCFrame(hitData, extraGap)
    if not hitData or not hitData.result or not hitData.hrp then return nil end
    local hrp = hitData.hrp
    local res = hitData.result
    local normal = res.Normal
    local nXZ = Vector3.new(normal.X, 0, normal.Z)
    if nXZ.Magnitude < 0.001 then
        nXZ = Vector3.new(hitData.dir.X, 0, hitData.dir.Z).Unit
    else
        nXZ = nXZ.Unit
    end
    local halfExtent = (math.abs(nXZ.X) * hrp.Size.X + math.abs(nXZ.Z) * hrp.Size.Z) * 0.5
    local gap = extraGap or 0.05
    local snapPos = Vector3.new(res.Position.X, hrp.Position.Y, res.Position.Z) + (nXZ * (halfExtent + gap))
    local lookAt = snapPos - nXZ
    return CFrame.lookAt(snapPos, lookAt)
end

local function debugWallScan()
    local hitData = findNearestWallHit(80)
    if not hitData then
        pcall(function() ShowNotification("WALL SCAN", "No hit") end)
        return
    end
    local res = hitData.result
    local inst = res.Instance
    pcall(function()
        ShowNotification("WALL SCAN", tostring(inst.Name) .. "  d=" .. string.format("%.2f", (res.Position - hitData.origin).Magnitude))
    end)
    print("WALL_SCAN_HRP", hitData.hrp.Position)
    print("WALL_SCAN_HIT", res.Position, "NORMAL", res.Normal, "DIST", (res.Position - hitData.origin).Magnitude)
    if inst then
        print("WALL_SCAN_PART", inst:GetFullName(), "SIZE", inst.Size, "CFRAME", inst.CFrame)
    end
    local snap = computeWallSnapCFrame(hitData, 0.05)
    if snap then
        print("WALL_SCAN_SNAP_CFRAME", snap)
    end
end

