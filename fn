        local function isBlacklistedLabel(text)
            if not text or text == "" then return true end
            local u = text:upper():match("^%s*(.-)%s*$")
            if #u <= 1 then return true end
            -- Ignora valores monetários
            if u:match("^%$") or u:match("/S$") then return true end
            if u:match("^[%d%.]+[KkMmBb]?$") then return true end
            for _, word in ipairs(CONVEYOR_LABEL_BLACKLIST) do
                if u == word or u:find("^" .. word .. "$") then return true end
            end
            return false
        end

        local function extractFromModelLabels(model)
            if not model then return nil, nil, nil end
            local bestName, bestGen, bestGV = nil, nil, 0
            for _, bb in ipairs(model:GetDescendants()) do
                if bb:IsA("BillboardGui") or bb:IsA("SurfaceGui") or bb:IsA("ScreenGui") then
                    for _, d in ipairs(bb:GetDescendants()) do
                        if d:IsA("TextLabel") and d.Text then
                            local val = parseGeneration(d.Text)
                            if val and val > bestGV then
                                bestGV = val
                                bestGen = d.Text
                                local container = d.Parent
                                if container then
                                    local dName = nil
                                    -- Primeiro tenta label com Name == "DisplayName"
                                    for _, sib in ipairs(container:GetChildren()) do
                                        if sib:IsA("TextLabel") and sib.Name == "DisplayName" then
                                            if not isBlacklistedLabel(sib.Text) then
                                                dName = sib.Text; break
                                            end
                                        end
                                    end
                                    -- Fallback: label mais longo que não seja blacklist
                                    if not dName then
                                        local bestTxt, bestLen = nil, 0
                                        for _, sib in ipairs(container:GetChildren()) do
                                            if sib:IsA("TextLabel") then
                                                local clean = (sib.Text or ""):gsub("<[^>]+>", ""):match("^%s*(.-)%s*$")
                                                if not isBlacklistedLabel(clean) then
                                                    local l = #clean
                                                    if l > bestLen then bestTxt, bestLen = clean, l end
                                                end
                                            end
                                        end
                                        if bestTxt then dName = bestTxt end
                                    end
                                    if dName then bestName = dName end
                                end
                            end
                        end
                    end
                end
            end
            return bestName, bestGen, bestGV
        end

        local function getBrainrotName(model, nameFallback)
            if not model then return nameFallback or "Brainrot", "", 0 end
            
            local uiName, uiGen, uiGv = extractFromModelLabels(model)
            if uiName and uiGen and uiGv > 0 then
                return uiName, uiGen, uiGv
            end
            
            local nameFound,genFound = "",""
            local gvValue = 0
            for _, bb in ipairs(model:GetDescendants()) do
                if bb:IsA("BillboardGui") then
                    for _, lbl in ipairs(bb:GetDescendants()) do
                        if lbl:IsA("TextLabel") and lbl.Text and lbl.Text ~= "" then
                            local raw = lbl.Text:gsub("<[^>]+>", "")
                            local t = raw:match("^%s*(.-)%s*$")
                            local tl = t:lower()
                            if RARITY_WORDS[tl] then continue end
                            -- Ignora palavras blacklistadas
                            if isBlacklistedLabel(t) then continue end
                            if t:match("^%$[%d%.]+[KkMmBb]?/[Ss]$") then
                                if genFound=="" then 
                                    genFound=t
                                    local numStr, multiplier = t:match("^%$([%d%.]+)([KkMmBb]?)/[Ss]$")
                                    if numStr then
                                        local val = tonumber(numStr) or 0
                                        local mults = {k=1e3, m=1e6, b=1e9}
                                        local m = multiplier and mults[multiplier:lower()] or 1
                                        gvValue = val * m
                                    end
                                end; continue
                            end
                            if t:match("^%$[%d%.]+[KkMmBb]?$") then continue end
                            if t:match("^[%d%.]+[KkMmBb]?$") then continue end
                            if nameFound=="" and #t>1 then nameFound=t end
                        end
                    end
                end
            end
            
            if nameFound=="" and nameFallback and nameFallback~="" then nameFound = nameFallback end
            
            local function tryLookupAndSet(keyOrName)
                if not (AnimData and AnimShared and NumUtils) then return false end
                local info = AnimData[keyOrName]
                if info then
                    if info.DisplayName then nameFound = info.DisplayName end
                    local gv = AnimShared:GetGeneration(keyOrName,nil,nil,nil)
                    genFound = "$"..NumUtils:ToString(gv).."/s"
                    gvValue = gv or 0
                    return true
                end
                for k, v in pairs(AnimData) do
                    if v.DisplayName == keyOrName or k == keyOrName then
                        if v.DisplayName then nameFound = v.DisplayName end
                        local gv = AnimShared:GetGeneration(k,nil,nil,nil)
                        genFound = "$"..NumUtils:ToString(gv).."/s"
                        gvValue = gv or 0
                        return true
                    end
                end
                return false
            end
            
            if genFound=="" or gvValue==0 then
                pcall(function()
                    if not tryLookupAndSet(model.Name) then
                        if nameFound ~= "" then
                            tryLookupAndSet(nameFound)
                        end
                    end
                end)
            end
            
            if nameFound=="" then nameFound = model.Name~="" and model.Name or (nameFallback or "Brainrot") end
            return nameFound,genFound,gvValue
        end

        local function scanConveyor()
            local results = {}
            local visiblePets = {}
            local debris = Workspace:FindFirstChild("Debris") or Workspace
            
            for _, debrisChild in ipairs(debris:GetChildren()) do
                if not (debrisChild:IsA("Model") or debrisChild:IsA("BasePart")) then continue end
                local uiName, uiGen, uiGV = extractFromModelLabels(debrisChild)
                if uiGV and uiGV > 0 then
                    local basePart = debrisChild:IsA("BasePart") and debrisChild or (debrisChild:IsA("Model") and debrisChild.PrimaryPart)
                    if not basePart then
                        for _, child in ipairs(debrisChild:GetChildren()) do
                            if child:IsA("BasePart") then basePart = child; break end
                        end
                    end
                    if basePart then
                        table.insert(visiblePets, {
                            name = uiName, gen = uiGen, gv = uiGV,
                            part = basePart, model = debrisChild
                        })
                    end
                end
            end
            
            local convFolder2 = Workspace:FindFirstChild("Conveyor") or Workspace:FindFirstChild("Debris") or Workspace
            for _, obj in ipairs(convFolder2:GetDescendants()) do
                if not (obj:IsA("ProximityPrompt") and obj.Enabled) then continue end
                local txt = (obj.ActionText or ""):lower()
                if not (txt:find("purchase") or txt:find("comprar") or txt:find("buy")) then continue end
                
                local promptPart = obj.Parent
                if not promptPart then continue end
                local realPart = promptPart:IsA("Attachment") and promptPart.Parent or promptPart
                if not (realPart and realPart:IsA("BasePart")) then continue end
                
                local matchedPet = nil
                local minDistance = 15
                for _, vPet in ipairs(visiblePets) do
                    local dist = (vPet.part.Position - realPart.Position).Magnitude
                    if dist < minDistance then
                        minDistance = dist
                        matchedPet = vPet
                    end
                end
                
                local finalName, finalGen, finalGv, finalModel
                
                if matchedPet then
                    finalName = matchedPet.name
                    finalGen = matchedPet.gen
                    finalGv = matchedPet.gv
                    finalModel = matchedPet.model
                else
                    local nameFromPrompt = (obj.ActionText or "") .. " " .. (obj.ObjectText or "")
                    local extracted = nameFromPrompt:gsub("%s*%$.*", ""):gsub("Purchase", ""):gsub("purchase", ""):gsub("Comprar", ""):gsub("comprar", ""):gsub("Buy", ""):gsub("buy", ""):match("^%s*(.-)%s*$")
                    
                    local searchRoot = realPart
                    local cur = realPart
                    while cur and cur.Parent and cur.Parent ~= Workspace do
                        if cur.Parent.Name == "Debris" or cur.Parent.Name == "Plots" or cur.Parent.Name == "Map" or cur.Parent.Name:match("Conveyor") or cur.Parent.Name:match("Esteira") then break end
                        searchRoot = cur
                        cur = cur.Parent
                    end
                    
                    if extracted == "" then
                        extracted = searchRoot:GetAttribute("PetName") or searchRoot:GetAttribute("Name") or searchRoot:GetAttribute("Animal") or ""
                    end
                    
                    finalName, finalGen, finalGv = getBrainrotName(searchRoot, extracted)
                    finalModel = searchRoot
                end
                
                table.insert(results,{
                    name = finalName, gen = finalGen, gv = finalGv,
                    prompt = obj, part = realPart, model = finalModel,
                    source = "ESTEIRA", uid = "esteira_"..tostring(obj),
                })
            end
            return results
        end

