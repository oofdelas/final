_G.snapToWall = function(gap)
    local hitData = findNearestWallHit(80)
    local cf = computeWallSnapCFrame(hitData, gap or 0.05)
    if cf and hitData and hitData.hrp and hitData.hrp.Parent then
        _G._tpPlannedRot = cf - cf.Position
        hitData.hrp.CFrame = cf
    end
    return hitData and hitData.result
end


