        end

        -- Se houver exigência de MinGen, esperamos o cache estabilizar um pouco
        local minGen = parseMinGen(Config.TpSettings.MinGenForTp)
        if minGen > 0 then
            local waitCache = 0
            while (not SharedState.AllAnimalsCache or #SharedState.AllAnimalsCache == 0) and waitCache < 200 do
                RunService.Heartbeat:Wait()
                waitCache = waitCache + 1
            end
            local cache = SharedState.AllAnimalsCache or {}
            local highestGen = (cache[1] and cache[1].genValue) or 0
            if highestGen < minGen then
                return
            end
        end

        -- Aguarda tpToBestBrainrot estar disponível (definido no bloco do da UI)
        local waitFn = 0
        while not _G.tpToBestBrainrot and waitFn < 30 do
            RunService.Heartbeat:Wait()
            waitFn = waitFn + 1
        end

        if _G.tpToBestBrainrot then
            pcall(_G.tpToBestBrainrot)
        else
            runAutoSnipe()
        end
    end)
end

