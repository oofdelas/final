task.spawn(function()
    if not game:IsLoaded() then game.Loaded:Wait() end

    if Config.BaseDefenderEnabled == nil then Config.BaseDefenderEnabled = false end

    local commandRotation = {"ragdoll", "balloon", "rocket"}
    local rotationIndex   = 1
    local lastCmdTime     = {}
    local CMD_COOLDOWN    = 6

    local function canCmd(plrName, cmd)
        local key = plrName .. "_" .. cmd
        local last = lastCmdTime[key]
        if last and (tick() - last) < CMD_COOLDOWN then return false end
        if isOnCooldown and isOnCooldown(cmd) then return false end
        return true
    end

    local function markCmdUsed(plrName, cmd)
        lastCmdTime[plrName .. "_" .. cmd] = tick()
    end

    local function getNextCmd()
        for i = 0, #commandRotation - 1 do
            local idx = ((rotationIndex - 1 + i) % #commandRotation) + 1
            local cmd = commandRotation[idx]
            if not (isOnCooldown and isOnCooldown(cmd)) then
                rotationIndex = (idx % #commandRotation) + 1
                return cmd
            end
        end
        return nil
    end

    local function isStealingMyBase(plr)
        if not plr or plr == LocalPlayer then return false end
        if not plr:GetAttribute("Stealing") then return false end
        local stealIdx = plr:GetAttribute("StealingIndex")
        if not stealIdx or stealIdx == "" then return false end
        local cache = SharedState.AllAnimalsCache
        if not cache then return false end
        for _, a in ipairs(cache) do
            if a and a.name == stealIdx and isMyBaseAnimal(a) then
                return true, a.name
            end
        end
        return false
    end

    -- Expor ANTES do loop para que o botão funcione imediatamente
    _G.BaseDefenderSetActive = function(val)
        Config.BaseDefenderEnabled = val
    end
    _G.isStealingMyBase = isStealingMyBase

    -- Loop principal — lê Config.BaseDefenderEnabled diretamente
    while true do
        task.wait(0.3)
        if not Config.BaseDefenderEnabled then continue end

        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer then continue end
            local ok, brainrotName = isStealingMyBase(plr)
            if not ok then continue end

            local cmd = getNextCmd()
            if not cmd then continue end
            if not canCmd(plr.Name, cmd) then continue end

            if _G.runAdminCommand then
                local success = _G.runAdminCommand(plr, cmd)
                if success then
                    markCmdUsed(plr.Name, cmd)
                    ShowNotification("BASE DEFENDER", cmd:upper() .. " → " .. plr.Name)
                end
            end
        end
    end
end)
