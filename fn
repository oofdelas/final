    local function convNameOk(text)
        if not text or text == "" then return false end
        local clean = text:gsub("<[^>]+>",""):match("^%s*(.-)%s*$") or ""
        if #clean <= 1 then return false end
        local u = clean:upper()
        if u:find("^%$") or u:find("/S$") or u:find("^[%d%.]+") then return false end
        if CONV_NAME_BLACKLIST[u] then return false end
        if RARITY_WORDS_CONV[clean:lower()] then return false end
        return true
    end

    local function parseGenConv(text)
        if type(text) ~= "string" then return nil end
        local txt = text:gsub("<[^>]+>", "")
        local upper = txt:upper()
        if not upper:find("%$") or not upper:find("/S") then return nil end
        if upper:find("FUSING") or upper:find("CRAFTING") then return nil end
        local clean = upper:gsub("%$", ""):gsub("/S", ""):gsub("%s+", "")
        local number = tonumber(clean:match("[%d%.]+"))
        if not number then return nil end
        if clean:find("B") then return number * 1e9
        elseif clean:find("M") then return number * 1e6
        elseif clean:find("K") then return number * 1e3
        else return number end
    end

    local function extractNameGenFromModel(model)
        if not model then return nil, nil, 0 end
        local bestName, bestGen, bestGV = nil, nil, 0
        -- Varrer só BillboardGuis diretos do model, não GetDescendants completo
        for _, bb in ipairs(model:GetChildren()) do
            if bb:IsA("BillboardGui") or bb:IsA("SurfaceGui") then
                for _, d in ipairs(bb:GetDescendants()) do
                    if d:IsA("TextLabel") and d.Text then
                        local val = parseGenConv(d.Text)
                        if val and val > bestGV then
                            bestGV = val
                            bestGen = d.Text:gsub("<[^>]+>", "")
                            -- Procurar nome no mesmo container
                            local container = d.Parent
                            if container then
                                for _, sib in ipairs(container:GetChildren()) do
                                    if sib:IsA("TextLabel") and sib ~= d then
                                        local clean = (sib.Text or ""):gsub("<[^>]+>",""):match("^%s*(.-)%s*$")
                                        if clean and convNameOk(clean) then
                                            bestName = clean; break
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
        -- Fallback: um nível mais fundo se não encontrou
        if not bestName then
            for _, child in ipairs(model:GetChildren()) do
                for _, bb in ipairs(child:GetChildren()) do
                    if bb:IsA("BillboardGui") or bb:IsA("SurfaceGui") then
                        for _, d in ipairs(bb:GetChildren()) do
                            if d:IsA("TextLabel") and d.Text then
                                local val = parseGenConv(d.Text)
                                if val and val > bestGV then
                                    bestGV = val
                                    bestGen = d.Text:gsub("<[^>]+>","")
                                end
                            end
                        end
                    end
                end
            end
        end
        return bestName, bestGen, bestGV
    end

    local function scanConveyorIndep()
        local results = {}
        local Workspace = game:GetService("Workspace")

        -- Coleta todos os pets visíveis pelo UI primeiro
        local visiblePets = {}
        local debris = Workspace:FindFirstChild("Debris") or Workspace
        for _, child in ipairs(debris:GetChildren()) do
            if child:IsA("Model") or child:IsA("BasePart") then
                local n, g, gv = extractNameGenFromModel(child)
                if gv and gv > 0 then
                    local part = child:IsA("BasePart") and child or (child:IsA("Model") and child.PrimaryPart)
                    if not part then
                        for _, c in ipairs(child:GetChildren()) do
                            if c:IsA("BasePart") then part = c; break end
                        end
                    end
                    if part then
                        table.insert(visiblePets, {name=n, gen=g, gv=gv, part=part, model=child})
                    end
                end
            end
        end

        -- Encontra ProximityPrompts de compra (só na pasta Conveyor, evita GetDescendants do Workspace todo)
        local conveyorFolder = Workspace:FindFirstChild("Conveyor") or Workspace:FindFirstChild("Debris") or Workspace
        for _, obj in ipairs(conveyorFolder:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and obj.Enabled then
                local txt = (obj.ActionText or ""):lower()
                if txt:find("purchase") or txt:find("comprar") or txt:find("buy") then
                    local promptPart = obj.Parent
                    if not promptPart then continue end
                    local realPart = promptPart:IsA("Attachment") and promptPart.Parent or promptPart
                    if not (realPart and realPart:IsA("BasePart")) then continue end

                    local finalName, finalGen, finalGv, finalModel = "Brainrot", "", 0, nil

                    -- Tenta casar com um pet visível
                    local minDist, matched = 15, nil
                    for _, vPet in ipairs(visiblePets) do
                        local d = (vPet.part.Position - realPart.Position).Magnitude
                        if d < minDist then minDist = d; matched = vPet end
                    end

                    if matched then
                        finalName = matched.name or "Brainrot"
                        finalGen  = matched.gen or ""
                        finalGv   = matched.gv or 0
                        finalModel = matched.model
                    else
                        -- Fallback: busca no parente do prompt
                        local searchRoot = realPart
                        local cur = realPart
                        while cur and cur.Parent and cur.Parent ~= Workspace do
                            searchRoot = cur; cur = cur.Parent
                        end
                        local n, g, gv = extractNameGenFromModel(searchRoot)
                        if n then finalName = n end
                        if g then finalGen = g end
                        if gv and gv > 0 then finalGv = gv end
                        finalModel = searchRoot
                    end

                    table.insert(results, {
                        name   = finalName,
                        gen    = finalGen,
                        gv     = finalGv,
                        prompt = obj,
                        part   = realPart,
                        model  = finalModel,
                        uid    = "conv_" .. tostring(obj),
                    })
                end
            end
        end
        return results
    end

    -- Loop de scan contínuo
    while true do
        local ok, found = pcall(scanConveyorIndep)
        if ok and found then
            SharedState.ConveyorAnimals = found
        end
        task.wait(0.3)
    end
end)

