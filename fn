function isBlacklisted(username)
    if not username then return false end
    local lower = string.lower(tostring(username))
    for _, v in ipairs(BlacklistedPlayers) do
        if string.lower(tostring(v)) == lower then
            return true
        end
    end
    return false
end

function addToBlacklist(username)
    if not username or username == "" then return false end
    if isBlacklisted(username) then return false end
    table.insert(BlacklistedPlayers, tostring(username))
    Config.Blacklist = BlacklistedPlayers
    SaveConfig()
    return true
end

function removeFromBlacklist(username)
    if not username or username == "" then return false end
    local lower = string.lower(tostring(username))
    for i, v in ipairs(BlacklistedPlayers) do
        if string.lower(tostring(v)) == lower then
            table.remove(BlacklistedPlayers, i)
            Config.Blacklist = BlacklistedPlayers
            SaveConfig()
            if _G.removeBlacklistESP then
                local p = Players:FindFirstChild(tostring(username))
                if p then pcall(_G.removeBlacklistESP, p) end
            end
            return true
        end
    end
    return false
end

