    -- Encontra o ProximityPrompt do animal no PRÓPRIO plot
    -- Palavras que identificam o prompt de STEAL (não "Allow Friends", "Toggle", etc.)
    local STEAL_PROMPT_KEYWORDS = {"steal", "roubar", "collect", "coletar", "take", "pegar", "grab"}
    local IGNORE_PROMPT_KEYWORDS = {"allow", "toggle", "friends", "lock", "unlock", "friend"}

    local function isStealPrompt(prompt)
        local action = (prompt.ActionText or ""):lower()
        local obj    = (prompt.ObjectText or ""):lower()
        -- Ignorar explicitamente prompts que não são de steal
        for _, kw in ipairs(IGNORE_PROMPT_KEYWORDS) do
            if action:find(kw) or obj:find(kw) then return false end
        end
        -- Aceitar se tiver keyword de steal
        for _, kw in ipairs(STEAL_PROMPT_KEYWORDS) do
            if action:find(kw) or obj:find(kw) then return true end
        end
        -- Aceitar se ActionText for vazio ou genérico (jogos usam "E" ou sem texto)
        -- mas só se o parent for um Spawn/AnimalPodium
        local parent = prompt.Parent
        if parent and (parent.Name == "PromptAttachment" or parent.Name == "Spawn") then
            return true
        end
        return false
    end

    local function findOwnPrompt(animalData)
        if not animalData or not animalData.plot then return nil end
        local plots = workspace:FindFirstChild("Plots")
        if not plots then return nil end
        local plot = plots:FindFirstChild(animalData.plot)
        if not plot then return nil end
        local podiums = plot:FindFirstChild("AnimalPodiums")
        if not podiums then return nil end

        -- Tenta pelo slot exato primeiro
        for _, pod in ipairs(podiums:GetChildren()) do
            if animalData.slot and pod.Name ~= tostring(animalData.slot) then continue end
            local base  = pod:FindFirstChild("Base")
            local spawn = base and base:FindFirstChild("Spawn")
            if not spawn then continue end
            local att    = spawn:FindFirstChild("PromptAttachment")
            local prompt = att and att:FindFirstChildOfClass("ProximityPrompt")
            if prompt and prompt.Enabled and isStealPrompt(prompt) then
                return prompt, spawn
            end
            -- Checar diretamente no spawn também
            for _, child in ipairs(spawn:GetChildren()) do
                if child:IsA("ProximityPrompt") and child.Enabled and isStealPrompt(child) then
                    return child, spawn
                end
            end
        end

        -- Fallback: qualquer prompt de steal no plot (excluindo Allow Friends etc)
        -- Buscar só em AnimalPodiums em vez de todo o plot
        local podiums2 = plot:FindFirstChild("AnimalPodiums")
        local searchRoot = podiums2 or plot
        for _, desc in ipairs(searchRoot:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled and isStealPrompt(desc) then
                local part = desc.Parent
                if part:IsA("Attachment") then part = part.Parent end
                return desc, part
            end
        end
        return nil
    end

    -- Executa o steal no próprio brainrot usando bypass completo
    local function executePickup(prompt)
        if not prompt or not prompt.Parent then return end
        -- Usa o mesmo bypass do instant steal
        if _G.executeInstantSteal then
            _G.executeInstantSteal(prompt)
        else
            -- Fallback: buildStealCallbacks manual
            local data = InternalStealCache and InternalStealCache[prompt]
            if not data then
                -- tenta montar callbacks
                local ok1, conns1 = pcall(getconnections, prompt.PromptButtonHoldBegan)
                local ok2, conns2 = pcall(getconnections, prompt.Triggered)
                if ok1 and ok2 then
                    local oDur = prompt.HoldDuration
                    prompt.HoldDuration = 0
                    if ok1 then for _, c in ipairs(conns1) do if type(c.Function)=="function" then pcall(c.Function) end end end
                    if ok2 then for _, c in ipairs(conns2) do if type(c.Function)=="function" then pcall(c.Function) end end end
                    if fireproximityprompt then pcall(fireproximityprompt, prompt) end
                    prompt.HoldDuration = oDur
                    return
                end
            end
            if data then
                local oDur = prompt.HoldDuration
                prompt.HoldDuration = 0
                for _, fn in ipairs(data.holdCallbacks) do pcall(fn) end
                for _, fn in ipairs(data.triggerCallbacks) do pcall(fn) end
                if fireproximityprompt then pcall(fireproximityprompt, prompt) end
                for _, fn in ipairs(data.holdEndCallbacks) do pcall(fn) end
                prompt.HoldDuration = oDur
            end
        end
    end

