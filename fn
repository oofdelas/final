_G._isTargetPlotUnlocked = function(plotName)
    local ok, res = pcall(function()
        local plots = Workspace:FindFirstChild("Plots")
        if not plots then return false end
        local targetPlot = plots:FindFirstChild(plotName)
        if not targetPlot then return false end
        local unlockFolder = targetPlot:FindFirstChild("Unlock")
        if not unlockFolder then return true end
        local unlockItems = {}
        for _, item in pairs(unlockFolder:GetChildren()) do
            local pos = nil
            if item:IsA("Model") then pcall(function() pos = item:GetPivot().Position end)
            elseif item:IsA("BasePart") then pos = item.Position end
            if pos then table.insert(unlockItems, {Object = item, Height = pos.Y}) end
        end
        table.sort(unlockItems, function(a, b) return a.Height < b.Height end)
        if #unlockItems == 0 then return true end
        local floor1Door = unlockItems[1].Object
        for _, desc in ipairs(floor1Door:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then return false end
        end
        for _, child in ipairs(floor1Door:GetChildren()) do
            if child:IsA("ProximityPrompt") and child.Enabled then return false end
        end
        return true
    end)
    return ok and res or false
end

local function runAutoSnipe()
    if State.isTpMoving then return end
    
    if State.carpetSpeedEnabled then
        setCarpetSpeed(false)
        if _carpetStatusLabel then
            _carpetStatusLabel.Text = "OFF"
            _carpetStatusLabel.TextColor3 = Theme.Error
        end
    end

    local targetPetData = nil
    if Config.AutoTPPriority then
        local bestEntry = nil
        local cache = SharedState.AllAnimalsCache
        if cache and type(cache) == "table" then
            for _, pName in ipairs(PRIORITY_LIST) do
                local searchName = pName:lower()
                for _, a in ipairs(cache) do
                    if a and a.name and a.name:lower() == searchName and a.owner ~= LocalPlayer.Name and not isBlacklisted(a.owner) then
                        bestEntry = a
                        break
                    end
                end
                if bestEntry then break end
            end
            if not bestEntry then
                for _, a in ipairs(cache) do
                    if a and a.owner ~= LocalPlayer.Name and not isBlacklisted(a.owner) then
                        bestEntry = a
                        break
                    end
                end
            end
        end
        if bestEntry then
            targetPetData = bestEntry
        else
            if not SharedState.SelectedPetData then ShowNotification("ERROR","No target selected!"); return end
            targetPetData = SharedState.SelectedPetData.animalData
        end
    else
        if not SharedState.SelectedPetData then ShowNotification("ERROR","No target selected!"); return end
        targetPetData = SharedState.SelectedPetData.animalData
    end
    if not targetPetData then return end

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    
    if not hrp or not hum or hum.Health <= 0 then return end

    local savedAutoRotate = hum.AutoRotate
    pcall(function() hum.AutoRotate = false end)
    _G._tpPlannedRot = nil
    
    State.isTpMoving = true
    isTpMoving = State.isTpMoving
    
    local targetPart = findAdorneeGlobal(targetPetData)
    if not targetPart then 
        State.isTpMoving = false
        isTpMoving = State.isTpMoving
        return 
    end
    
    local exactPos = targetPart.Position
    local carpetName = Config.TpSettings.Tool
    local carpet = LocalPlayer.Backpack:FindFirstChild(carpetName) or char:FindFirstChild(carpetName)
    local cloner = LocalPlayer.Backpack:FindFirstChild("Quantum Cloner") or char:FindFirstChild("Quantum Cloner")

    if carpet then hum:EquipTool(carpet) end
    task.wait(0.01)
    task.wait(tonumber(Config.TpSettings.StartDelay) or 0.15)

    local plotObj = Workspace:FindFirstChild("Plots") and Workspace.Plots:FindFirstChild(targetPetData.plot)
    local plotRootPart = plotObj and (plotObj:FindFirstChild("MainRootPart") or plotObj:FindFirstChildWhichIsA("BasePart"))
    local plotCenter   = plotRootPart and plotRootPart.Position or exactPos

    -- TP fixo (original): vizinho “à frente” na fileira = vetor DA TUA base → base alvo alinhado com onde estás / olhar.
    -- O critério antigo (só hrp → plotCenter + LookVector) falhava na lateral.
    local function findMyPlotCenterForTp()
        local plots = Workspace:FindFirstChild("Plots")
        if not plots then return nil, nil end
        for _, plot in ipairs(plots:GetChildren()) do
            local sign = plot:FindFirstChild("PlotSign")
            if sign then
                local sg = sign:FindFirstChildWhichIsA("SurfaceGui", true)
                if sg then
                    local label = sg:FindFirstChildWhichIsA("TextLabel", true)
                    if label then
                        local text = label.Text:lower()
                        if text:find(LocalPlayer.DisplayName:lower(), 1, true) or text:find(LocalPlayer.Name:lower(), 1, true) then
                            local root = plot:FindFirstChild("MainRootPart") or plot:FindFirstChildWhichIsA("BasePart")
                            return plot.Name, root and root.Position or nil
                        end
                    end
                end
            end
        end
        return nil, nil
    end

    local myPlotName, myPlotPos = findMyPlotCenterForTp()
    local useLegacyTp = false
    if myPlotPos and plotObj and myPlotName ~= targetPetData.plot then
        local myIdx = getClosestBaseIdx(myPlotPos)
        local frontIdx = (myIdx <= 4) and (myIdx + 4) or (myIdx - 4)
        local targetIdx = getClosestBaseIdx(plotCenter)
        useLegacyTp = (targetIdx == frontIdx)
    end
    if not myPlotPos or myPlotName == targetPetData.plot then
        useLegacyTp = false
    end

    local rotBeforeEnteringBase
    local holdConn = nil

    if useLegacyTp then
        -- TP fixo = original.txt por completo (altura min 50, impulso 280, 1º/2º como lá, FACE_TARGETS, etc.)
        local isLegacySecondFloor = exactPos.Y > 10
        local plotIndex = getClosestBaseIdx(exactPos)
        local targetBasePos = isLegacySecondFloor and BASES_HIGH[plotIndex] or BASES_LOW[plotIndex]
        local minHeight = 50
        local targetHeight = math.max(targetBasePos.Y, minHeight)
        local jumpStart = tick()
        while hrp.Position.Y < targetHeight and (tick() - jumpStart) < 2 do
            hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 280, hrp.AssemblyLinearVelocity.Z)
            RunService.Heartbeat:Wait()
        end
        for i = 1, 8 do
            hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
            if (hrp.Position - targetBasePos).Magnitude > 3 then
                hrp.CFrame = CFrame.new(targetBasePos)
                task.wait(0.03)
            end
        end
        if not isLegacySecondFloor then
            local bestSpot = CLONE_POSITIONS_FLOOR[1]
            local minDst = math.huge
            for _, v in ipairs(CLONE_POSITIONS_FLOOR) do
                local d = (targetPart.Position - v).Magnitude
                if d < minDst then minDst = d; bestSpot = v end
            end
            for i = 1, 4 do
                if (hrp.Position - bestSpot).Magnitude > 3 then
                    hrp.CFrame = CFrame.new(bestSpot)
                    task.wait(0.03)
                end
            end
        end
        local bestFace = FACE_TARGETS[1]
        local minFaceDist = math.huge
        for _, v in ipairs(FACE_TARGETS) do
            local d = (hrp.Position - v).Magnitude
            if d < minFaceDist then minFaceDist = d; bestFace = v end
        end
        task.wait(0.01)
        local plannedRot = _G._tpPlannedRot
        if plannedRot then
            hrp.CFrame = CFrame.new(hrp.Position) * plannedRot
            rotBeforeEnteringBase = plannedRot
        else
            hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(bestFace.X, hrp.Position.Y, bestFace.Z))
            rotBeforeEnteringBase = hrp.CFrame - hrp.Position
        end
        pcall(function() hrp.AssemblyAngularVelocity = Vector3.zero end)

        -- Igual ao original: só clone se 2º andar OU base fechada no 1º; sem mexer em AutoRotate
        if isLegacySecondFloor or not _G._isTargetPlotUnlocked(targetPetData.plot) then
            walkForward(0.25)
            task.wait(0.15)
            instantClone()
            while _G.isCloning do task.wait() end
            task.wait(0.05)
            task.wait(0.15)
        end
        task.wait(0.10)
    else
    local isSecondFloor = exactPos.Y > 11.5
    -- Posicionamento DINAMICO: lê as posições reais dos slots do plot alvo

    -- Coleta slots do 1o andar para calcular X/Z da lateral
    -- (sempre usamos a geometria do 1o andar para saber o canto certo no eixo X/Z)
    local slotPositions = {}
    local podiums = plotObj and plotObj:FindFirstChild("AnimalPodiums")
    if podiums then
        for _, pod in ipairs(podiums:GetChildren()) do
            local base  = pod:FindFirstChild("Base")
            local spawn = base and (base:FindFirstChild("Spawn") or base:FindFirstChildWhichIsA("BasePart"))
                       or pod:FindFirstChildWhichIsA("BasePart")
            if spawn and spawn.Position.Y <= 10 then
                table.insert(slotPositions, spawn.Position)
            end
        end
    end

    -- Calcula extremos X/Z dos slots do 1o andar
    local slotCenterX = plotCenter.X
    local slotCenterZ = plotCenter.Z
    local slotMinZ    = plotCenter.Z - 18
    local slotMaxZ    = plotCenter.Z + 18
    local slotMinX    = plotCenter.X
    local slotMaxX    = plotCenter.X

    -- Y do 2o andar = 11.8 (detectado pelo script detector)
    -- Y do 1o andar = -6.2 (detectado pelo script detector)
    local slotFloorY  = isSecondFloor and 11.8 or -6.2

    if #slotPositions > 0 then
        local sumX = 0
        local minZ, maxZ = math.huge, -math.huge
        local minX, maxX = math.huge, -math.huge
        local sumY1, count1 = 0, 0
        for _, p in ipairs(slotPositions) do
            sumX = sumX + p.X
            if p.Z < minZ then minZ = p.Z end
            if p.Z > maxZ then maxZ = p.Z end
            if p.X < minX then minX = p.X end
            if p.X > maxX then maxX = p.X end
            sumY1 = sumY1 + p.Y
            count1 = count1 + 1
        end
        slotCenterX = sumX / #slotPositions
        slotMinZ    = minZ
        slotMaxZ    = maxZ
        slotMinX    = minX
        slotMaxX    = maxX
        slotCenterZ = (minZ + maxZ) / 2
        -- So usa Y dos slots para o 1o andar
        if not isSecondFloor then
            slotFloorY = sumY1 / count1
        end
    end

    -- Escolhe o lado Z mais proximo do player (norte ou sul da base)
    local OUTSIDE_OFFSET = 8
    local zOutsideNorth = slotMaxZ + OUTSIDE_OFFSET
    local zOutsideSouth = slotMinZ - OUTSIDE_OFFSET

    local zPrimary, zFallback
    if math.abs(hrp.Position.Z - zOutsideNorth) <= math.abs(hrp.Position.Z - zOutsideSouth) then
        zPrimary  = zOutsideNorth
        zFallback = zOutsideSouth
    else
        zPrimary  = zOutsideSouth
        zFallback = zOutsideNorth
    end

    -- Raycast para detectar obstaculo no lado candidato
    local cornerX = (math.abs(hrp.Position.X - slotMinX) <= math.abs(hrp.Position.X - slotMaxX))
                    and slotMinX or slotMaxX

    local function sideIsClear(testZ)
        local rayOrigin = Vector3.new(cornerX, slotFloorY + 10, testZ)
        local rayDir    = Vector3.new(0, -15, 0)
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
        local result = Workspace:Raycast(rayOrigin, rayDir, rayParams)
        if result then return result.Position.Y < (slotFloorY + 3) end
        return true
    end

    local chosenZ = sideIsClear(zPrimary) and zPrimary or zFallback

    -- Um pouco acima do piso para não nascer grudado no chão / clipar
    local TP_GROUND_LIFT = 3.5
    local sideY    = slotFloorY + TP_GROUND_LIFT
    local sideSpot = Vector3.new(cornerX, sideY, chosenZ)

    -- Um eixo fixo para todo o TP (não muda a meio do arco): evita um lado “trocar” de parede e bugar.
    -- Se a saída é mais forte em Z (beira norte/sul), olhar só em Z; senão só em X (beira leste/oeste).
    local inwardPrimaryZ = math.abs(chosenZ - slotCenterZ) >= math.abs(cornerX - slotCenterX)

    local function lookStraightInwardFrom(pos)
        local y = pos.Y
        if inwardPrimaryZ then
            local t = Vector3.new(pos.X, y, slotCenterZ)
            if (t - pos).Magnitude > 0.05 then return CFrame.lookAt(pos, t) end
            t = Vector3.new(slotCenterX, y, pos.Z)
            if (t - pos).Magnitude > 0.05 then return CFrame.lookAt(pos, t) end
        else
            local t = Vector3.new(slotCenterX, y, pos.Z)
            if (t - pos).Magnitude > 0.05 then return CFrame.lookAt(pos, t) end
            t = Vector3.new(pos.X, y, slotCenterZ)
            if (t - pos).Magnitude > 0.05 then return CFrame.lookAt(pos, t) end
        end
        return CFrame.lookAt(pos, pos + Vector3.new(0, 0, chosenZ >= slotCenterZ and -1 or 1))
    end

    -- Rotação FINAL da beira calculada só com sideSpot — aplica desde já (dentro da base também).
    -- Se usar lookStraightInwardFrom(hrp.Position) no início, a posição interior calcula yaw errado e “troca o lado” ao chegar.
    local approachRotAtSide = _G._tpPlannedRot or (lookStraightInwardFrom(sideSpot) - sideSpot)
    if not _G._tpPlannedRot then
        _G._tpPlannedRot = approachRotAtSide
    end

    hrp.CFrame = CFrame.new(hrp.Position) * approachRotAtSide
    task.wait(0.01)

    -- Arco baixo: pouco clearance acima do chão da beira (evita o “foguete” e a queda longa)
    local ARC_CLEAR = 10
    local targetHeight = sideSpot.Y + ARC_CLEAR

    local jumpStart = tick()
    while hrp.Position.Y < targetHeight and (tick() - jumpStart) < 1.2 do
        hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 140, hrp.AssemblyLinearVelocity.Z)
        RunService.Heartbeat:Wait()
    end

    local midPos = Vector3.new(sideSpot.X, targetHeight, sideSpot.Z)
    for i = 1, 3 do
        hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
        if (hrp.Position - midPos).Magnitude > 2 then
            hrp.CFrame = CFrame.new(midPos) * approachRotAtSide
            task.wait(0.03)
        end
    end

    for i = 1, 3 do
        if (hrp.Position - sideSpot).Magnitude > 2 then
            hrp.CFrame = CFrame.new(sideSpot) * approachRotAtSide
            task.wait(0.04)
        end
    end
    hrp.CFrame = CFrame.new(sideSpot) * approachRotAtSide
    hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
    pcall(function() hrp.AssemblyAngularVelocity = Vector3.zero end)

    pcall(function()
        if not _G._tpPlannedRot then
            _G._tpPlannedRot = approachRotAtSide
        end
        if _G.snapToWall then
            _G.snapToWall(0.05)
        end
    end)
    rotBeforeEnteringBase = _G._tpPlannedRot or approachRotAtSide

    -- 2o andar: corrige só o Y sem resetar rotação (antes: CFrame.new(x,y,z) apagava o lookAt a cada frame)
    if isSecondFloor then
        holdConn = RunService.Heartbeat:Connect(function()
            if hrp and hrp.Parent then
                hrp.AssemblyLinearVelocity = Vector3.new(
                    hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
                if math.abs(hrp.Position.Y - sideSpot.Y) > 1 then
                    local keepRot = hrp.CFrame - hrp.Position
                    hrp.CFrame = CFrame.new(hrp.Position.X, sideSpot.Y, hrp.Position.Z) * keepRot
                end
            end
        end)
    end
    local wallOk = false
    pcall(function()
        if _G.snapToWall then
            wallOk = (_G.snapToWall(0.05) ~= nil)
        end
    end)
    if not wallOk then
        walkForward(0.20)
    end
    task.wait(0.15)
    instantClone()
    while _G.isCloning do task.wait() end
    task.wait(0.05) -- Delay para o clone ser concluído no servidor
    task.wait(0.15) -- Confirmação do clone antes de TP pro brainrot
    if holdConn then holdConn:Disconnect(); holdConn = nil end
    task.wait(0.10)
    end

    if carpet then hum:EquipTool(carpet) end

    local verticalDiff = targetPart.Position.Y - hrp.Position.Y

    if useLegacyTp then
        -- original.txt: só posição no brainrot (orientação padrão “pra frente”, não preservar yaw da beira)
        if verticalDiff > 2 then
            local airPos = Vector3.new(targetPart.Position.X, targetPart.Position.Y - 8, targetPart.Position.Z)
            local plat = Instance.new("Part")
            plat.Name = "XiTempPlatform"
            plat.Size = Vector3.new(3, 1, 3)
            plat.Position = airPos - Vector3.new(0, 5, 0)
            plat.Color = Color3.new(1, 0, 0)
            plat.Material = Enum.Material.Neon
            plat.Anchored = true
            plat.CanCollide = true
            plat.Transparency = 0.3
            plat.Parent = Workspace
            RunService.Heartbeat:Wait()
            for i = 1, 10 do
                if not LocalPlayer:GetAttribute("Stealing") then
                    hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
                    local rot = _G._tpPlannedRot or rotBeforeEnteringBase or (hrp.CFrame - hrp.Position)
                    hrp.CFrame = CFrame.new(airPos) * rot
                    task.wait(0.05)
                end
            end
            task.spawn(function()
                local start = tick()
                while tick() - start < 20 do
                    if LocalPlayer:GetAttribute("Stealing") then break end
                    task.wait(0.1)
                end
                plat:Destroy()
            end)
        else
            for i = 1, 10 do
                if LocalPlayer:GetAttribute("Stealing") then break end
                hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
                if (hrp.Position - targetPart.Position).Magnitude > 3 then
                    local rot = _G._tpPlannedRot or rotBeforeEnteringBase or (hrp.CFrame - hrp.Position)
                    hrp.CFrame = CFrame.new(targetPart.Position) * rot
                    task.wait(0.05)
                end
                task.wait(0.05)
            end
        end
    else
        local function atBrainrotKeepApproachLook(pos)
            return CFrame.new(pos) * rotBeforeEnteringBase
        end
        if verticalDiff > 2 then
            local airPos = Vector3.new(targetPart.Position.X, targetPart.Position.Y - 8, targetPart.Position.Z)
            local plat = Instance.new("Part")
            plat.Name = "XiTempPlatform"
            plat.Size = Vector3.new(3, 1, 3)
            plat.Position = airPos - Vector3.new(0, 5, 0)
            plat.Color = Color3.new(1, 0, 0)
            plat.Material = Enum.Material.Neon
            plat.Anchored = true
            plat.CanCollide = true
            plat.Transparency = 0.3
            plat.Parent = Workspace
            RunService.Heartbeat:Wait()
            for i = 1, 10 do
                if not LocalPlayer:GetAttribute("Stealing") then
                    hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
                    hrp.CFrame = atBrainrotKeepApproachLook(airPos)
                    task.wait(0.05)
                end
            end
            task.spawn(function()
                local start = tick()
                while tick() - start < 20 do
                    if LocalPlayer:GetAttribute("Stealing") then break end
                    task.wait(0.1)
                end
                plat:Destroy()
            end)
        else
            for i = 1, 10 do
                if LocalPlayer:GetAttribute("Stealing") then break end
                hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
                if (hrp.Position - targetPart.Position).Magnitude > 3 then
                    hrp.CFrame = atBrainrotKeepApproachLook(targetPart.Position)
                    task.wait(0.05)
                end
                task.wait(0.05)
            end
        end
    end
    
    pcall(function() hum.AutoRotate = savedAutoRotate end)
    State.isTpMoving = false
    isTpMoving = State.isTpMoving
end

if Config.TpSettings.TpOnLoad then
    task.spawn(function()
        local player = game.Players.LocalPlayer


        -- Aguarda o scanner estar 100% pronto (todos os plots lidos) — timeout reduzido
        local startScanner = tick()
        while not SharedState.ScannerReady and (tick() - startScanner) < 5 do
            RunService.Heartbeat:Wait()
        end

        -- Início agressivo: Tenta TP assim que qualquer pet for detectado
        while true do
