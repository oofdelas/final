    -- ============================================================
    --  TP TO BEST BRAINROT  (Base + Conveyor)
    -- ============================================================
    local function tpToBestBrainrot()
        if State.isTpMoving then return end

        -- Desativa Carpet Speed se estiver ativo
        if State.carpetSpeedEnabled then
            setCarpetSpeed(false)
            if _carpetStatusLabel then
                _carpetStatusLabel.Text      = "OFF"
                _carpetStatusLabel.TextColor3 = Theme.Error
            end
        end

        -- Força scan rápido do conveyor antes de decidir
        if _G.refreshConveyor then pcall(_G.refreshConveyor) end

        -- Melhor brainrot das BASES
        local bestBasePet = nil
        local bestBaseGv  = -1

        do
            local cache = SharedState.AllAnimalsCache
            if cache and type(cache) == "table" then
                -- Tenta por PRIORITY_LIST primeiro
                if Config.AutoTPPriority then
                    for _, pName in ipairs(PRIORITY_LIST) do
                        local searchName = pName:lower()
                        for _, a in ipairs(cache) do
                            if a and a.name and a.name:lower() == searchName
                               and a.owner ~= LocalPlayer.Name and not isBlacklisted(a.owner) then
                                bestBasePet = a
                                bestBaseGv  = tonumber(a.genValue) or 0
                                break
                            end
                        end
                        if bestBasePet then break end
                    end
                end

                -- Fallback: maior genValue (cache já está ordenado)
                if not bestBasePet then
                    for _, a in ipairs(cache) do
                        if a and a.owner ~= LocalPlayer.Name and not isBlacklisted(a.owner) then
                            local gv = tonumber(a.genValue) or 0
                            if gv > bestBaseGv then
                                bestBaseGv  = gv
                                bestBasePet = a
                            end
                            break -- primeiro válido já é o melhor
                        end
                    end
                end
            end
        end

        -- Melhor brainrot do CONVEYOR
        -- Usa SharedState.ConveyorAnimals que é atualizado pelo scan independente
        local bestConvPet = nil
        local bestConvGv  = -1

        do
            local convList = SharedState.ConveyorAnimals
            if convList and type(convList) == "table" then
                for _, entry in ipairs(convList) do
                    local valid = entry.prompt and entry.prompt.Parent
                                  and entry.prompt.Enabled
                                  and entry.part  and entry.part.Parent
                    local gv = tonumber(entry.gv) or 0
                    if valid and gv > bestConvGv then
                        bestConvGv  = gv
                        bestConvPet = entry
                    end
                end
            end
        end

        -- Exporta para o ESP (mantém compatibilidade)
        _G.BestBaseGv     = bestBaseGv
        _G.BestConveyorGv = bestConvGv

        -- Decide o alvo:
        --   conveyor vence se gen for estritamente maior que a base
        --   ou se não houver nenhum pet na base
        local useConveyor = false
        if bestConvPet and bestConvPet.part and bestConvPet.part.Parent then
            if not bestBasePet then
                useConveyor = true
            elseif bestConvGv > bestBaseGv then
                useConveyor = true
            end
        end

        if not bestBasePet and not bestConvPet then
            ShowNotification("TP BEST", "Nenhum brainrot encontrado no servidor!")
            return
        end

        -- ── TP PARA CONVEYOR ──────────────────────────────────────
        if useConveyor then
            local entry      = bestConvPet
            local targetPart = entry.part

            if not targetPart or not targetPart.Parent then
                -- Conveyor pet sumiu, tenta base
                if bestBasePet then
                    useConveyor = false
                else
                    ShowNotification("TP BEST", "Pet do conveyor sumiu, tente novamente.")
                    return
                end
            end
        end

        if useConveyor then
            local entry      = bestConvPet
            local targetPart = entry.part

            ShowNotification("TP BEST", "CONVEYOR -> " .. tostring(entry.name or "?") .. "  " .. tostring(entry.gen or "$0/s"))

            task.spawn(function()
                local char = LocalPlayer.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                local hum  = char and char:FindFirstChild("Humanoid")
                if not hrp or not hum or hum.Health <= 0 then return end
                task.wait(tonumber(Config.TpSettings.StartDelay) or 0.15)

                -- Equipa o carpet
                local carpetName = Config.TpSettings and Config.TpSettings.Tool or "Flying Carpet"
                local carpet = LocalPlayer.Backpack:FindFirstChild(carpetName)
                            or char:FindFirstChild(carpetName)
                if carpet then hum:EquipTool(carpet) end

                -- Impulso para cima primeiro, depois TP direto no pet
                hrp.AssemblyLinearVelocity = Vector3.new(0, 280, 0)
                RunService.Heartbeat:Wait()
                local rot = _G._tpPlannedRot or (hrp.CFrame - hrp.Position)
                hrp.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 3, 0)) * rot
            end)

            return
        end

        -- ── TP PARA BASE (impulso + TP intermediário + runAutoSnipe) ──
        if bestBasePet then
            ShowNotification("TP BEST", "BASE -> " .. tostring(bestBasePet.name) .. "  " .. tostring(bestBasePet.genText or ""))
            SharedState.SelectedPetData = {
                petName    = bestBasePet.name,
                mpsText    = bestBasePet.genText,
                mpsValue   = bestBasePet.genValue,
                owner      = bestBasePet.owner,
                plot       = bestBasePet.plot,
                slot       = bestBasePet.slot,
                uid        = bestBasePet.uid,
                mutation   = bestBasePet.mutation,
                animalData = bestBasePet,
            }
            task.spawn(function()
                local char = LocalPlayer.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                local hum  = char and char:FindFirstChild("Humanoid")
                if not hrp or not hum or hum.Health <= 0 then
                    runAutoSnipe()
                    return
                end
                task.wait(tonumber(Config.TpSettings.StartDelay) or 0.15)

                -- Equipa o carpet antes do impulso
                local carpetName = Config.TpSettings and Config.TpSettings.Tool or "Flying Carpet"
                local carpet = LocalPlayer.Backpack:FindFirstChild(carpetName)
                            or char:FindFirstChild(carpetName)
                if carpet then hum:EquipTool(carpet) end

                -- 1) Inicia o impulso para cima
                hrp.AssemblyLinearVelocity = Vector3.new(0, 100, 0)

                -- 2) Aguarda o personagem subir um pouco antes de teleportar
                task.wait(0.03)

                -- 3) Teleporta para a posição intermediária mantendo Z atual
                local rot = _G._tpPlannedRot or (hrp.CFrame - hrp.Position)
                hrp.CFrame = CFrame.new(Vector3.new(-413, 50, hrp.Position.Z)) * rot

                -- 4) Continua o impulso por mais alguns ms (para parecer natural)
                local impulseEnd = tick() + 0.035
                while tick() < impulseEnd do
                    hrp.AssemblyLinearVelocity = Vector3.new(0, 100, 0)
                    RunService.Heartbeat:Wait()
                end

                -- 5) Pausa leve antes de entregar ao runAutoSnipe
                task.wait(0.03)

                -- 6) Continua o TP normal para a base do pet (clone + ida ao brainrot)
                runAutoSnipe()
            end)
        end
    end

