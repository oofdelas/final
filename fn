    local function getBestPriorityPet()
        local bestPriorityPet = nil
        local bestRank = #PRIORITY_LIST + 1

        -- Verifica bases
        for _, pet in ipairs(allAnimalsCache) do
            if pet.name then
                local petLower = pet.name:lower()
                for rank, pName in ipairs(PRIORITY_LIST) do
                    if pName:lower() == petLower then
                        if rank < bestRank then
                            bestRank = rank
                            bestPriorityPet = pet
                        end
                        break
                    end
                end
            end
        end

        -- Verifica conveyor (esteira)
        local conveyorList = SharedState.ConveyorAnimals
        if conveyorList then
            for _, entry in ipairs(conveyorList) do
                local entryName = entry.name
                if entryName and entry.prompt and entry.prompt.Parent and entry.prompt.Enabled then
                    local entryLower = entryName:lower()
                    for rank, pName in ipairs(PRIORITY_LIST) do
                        if pName:lower() == entryLower then
                            if rank < bestRank then
                                bestRank = rank
                                bestPriorityPet = {
                                    name     = entry.name,
                                    genText  = entry.gen or "",
                                    genValue = entry.gv or 0,
                                    uid      = "conveyor_" .. tostring(entry.prompt),
                                    plot     = nil,
                                    slot     = nil,
                                    source   = "CONVEYOR",
                                }
                            end
                            break
                        end
                    end
                end
            end
        end

        return bestPriorityPet
    end
    
