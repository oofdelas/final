            secret=true,divine=true,rainbow=true,cursed=true,gold=true,diamond=true}

        local function parseGeneration(text)
            if type(text) ~= "string" then return nil end
            local txt = text:gsub("<[^>]+>", "")
            local upper = txt:upper()
            if not upper:find("%$") or not upper:find("/S") then return nil end
            if upper:find("FUSING") or upper:find("CRAFTING") then return nil end
            local clean = upper:gsub("%$", ""):gsub("/S", ""):gsub("%s+", "")
            local number = tonumber(clean:match("[%d%.]+"))
            if not number then return nil end
            if clean:find("B") then return number * 1e9
            elseif clean:find("M") then return number * 1e6
            elseif clean:find("K") then return number * 1e3
            else return number end
        end

        -- Palavras que NÃO são nomes de brainrot e devem ser ignoradas no ESP
        local CONVEYOR_LABEL_BLACKLIST = {
